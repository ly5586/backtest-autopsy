{
    "trading_mode": "futures",
    "margin_mode": "isolated",
    "max_open_trades": 3,
    "stake_currency": "USDT",
    "stake_amount": 500,
    "tradable_balance_ratio": 0.99,
    "dry_run": true,
    "dry_run_wallet": 5000,
    "cancel_open_orders_on_exit": true,
    "unfilledtimeout": {
        "entry": 10,
        "exit": 10,
        "unit": "minutes"
    },
    "exchange": {
        "name": "okx",
        "key": "YOUR_API_KEY",
        "secret": "YOUR_API_SECRET",
        "password": "YOUR_API_PASSPHRASE",
        "pair_whitelist": [
            "BTC/USDT:USDT",
            "ETH/USDT:USDT",
            "SOL/USDT:USDT",
            "DOGE/USDT:USDT",
            "ARB/USDT:USDT",
            "OP/USDT:USDT",
            "SUI/USDT:USDT",
            "LINK/USDT:USDT",
            "XRP/USDT:USDT",
            "XLM/USDT:USDT"
        ],
        "ccxt_config": {
            "timeout": 60000,
            "enableRateLimit": true,
            "options": {
                "defaultType": "swap"
            }
        },
        "ccxt_async_config": {
            "timeout": 60000,
            "enableRateLimit": true
        }
    },
    "pairlists": [
        {"method": "StaticPairList"}
    ],
    "timeframe": "5m",
    "fiat_display_currency": "USD",
    "entry_pricing": {
        "price_side": "ask",
        "use_order_book": true,
        "order_book_top": 1,
        "price_last_balance": 0.0
    },
    "exit_pricing": {
        "price_side": "bid",
        "use_order_book": true,
        "order_book_top": 1
    }
}
